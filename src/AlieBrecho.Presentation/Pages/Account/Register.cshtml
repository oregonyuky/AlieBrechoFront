@page
@model AlieBrecho.Presentation.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Cadastro";
}

<section class="auth-shell auth-shell-wide">
    <div class="auth-panel">
        <p class="eyebrow">Criar conta</p>
        <h1>Cadastro</h1>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="notice">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="notice-success">@Model.StatusMessage</div>
        }

        <form method="post" class="auth-form auth-form-grid">
            <input type="hidden" asp-for="ReturnUrl" />

            <label asp-for="Input.FirstName">
                Nome
                <input asp-for="Input.FirstName" autocomplete="given-name" />
                <span asp-validation-for="Input.FirstName"></span>
            </label>

            <label asp-for="Input.LastName">
                Sobrenome
                <input asp-for="Input.LastName" autocomplete="family-name" />
                <span asp-validation-for="Input.LastName"></span>
            </label>

            <label class="full" asp-for="Input.Email">
                E-mail
                <input asp-for="Input.Email" autocomplete="username" />
                <span asp-validation-for="Input.Email"></span>
            </label>

            <label class="full" asp-for="Input.Instagram">
                Instagram
                <input asp-for="Input.Instagram" autocomplete="off" placeholder="@@seuusuario" />
                <span asp-validation-for="Input.Instagram"></span>
            </label>

            <label asp-for="Input.Password">
                Senha
                <input asp-for="Input.Password" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.Password"></span>
            </label>

            <label asp-for="Input.ConfirmPassword">
                Confirmar senha
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword"></span>
            </label>

            <button class="button full" type="submit">Cadastrar cliente</button>
        </form>

        <a class="button button-secondary auth-existing-account"
           asp-page="/Account/Login"
           asp-route-returnUrl="@Model.ReturnUrl">Entrar em uma conta existente</a>

        <p class="auth-legal">
            Ao continuar, você concorda com os Termos de Serviço e confirma que leu a nossa
            <a href="https://www.pinterest.com/_/_/policy/privacy-policy/" target="_blank" rel="noopener noreferrer">Política de Privacidade</a>.
            <a href="https://policy.pinterest.com/notice-at-collection" target="_blank" rel="noopener noreferrer">Aviso na coleta de informações</a>.
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
