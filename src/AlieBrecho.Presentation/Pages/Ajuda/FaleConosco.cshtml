@page
@model AlieBrecho.Presentation.Pages.Ajuda.FaleConoscoModel
@{
    ViewData["Title"] = "Fale conosco";
}

<section class="contact-shell">
    <div class="contact-heading">
        <p class="eyebrow">Estamos aqui para ajudar</p>
        <h1>Fale <em>conosco</em></h1>
        <p>Envie sua dúvida ou solicitação. Nossa equipe responderá pelo e-mail informado.</p>
    </div>

    <div class="contact-card">
        <div class="contact-info-bar">
            <div>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6.5 12 13l9-6.5M4.5 5h15A1.5 1.5 0 0 1 21 6.5v11a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5v-11A1.5 1.5 0 0 1 4.5 5Z" /></svg>
                <a href="mailto:contato@aliebrecho.com.br">contato@aliebrecho.com.br</a>
            </div>
            <div>
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
                <span>Segunda a sexta, das 8h às 12h e das 14h às 17h</span>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="contact-notice contact-notice--success" role="status">@Model.StatusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="contact-notice contact-notice--error" role="alert">@Model.ErrorMessage</div>
        }

        <form method="post" class="contact-form">
            <div class="contact-field">
                <label asp-for="Input.Name"></label>
                <input asp-for="Input.Name" autocomplete="name" placeholder="Seu nome completo..." />
                <span asp-validation-for="Input.Name"></span>
            </div>

            <div class="contact-field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" autocomplete="email" placeholder="Seu e-mail..." />
                <span asp-validation-for="Input.Email"></span>
            </div>

            <div class="contact-field">
                <label asp-for="Input.Phone"></label>
                <input asp-for="Input.Phone" autocomplete="tel" inputmode="tel" placeholder="Seu telefone..." />
                <span asp-validation-for="Input.Phone"></span>
            </div>

            <div class="contact-field">
                <label asp-for="Input.Subject"></label>
                <input asp-for="Input.Subject" placeholder="O assunto..." />
                <span asp-validation-for="Input.Subject"></span>
            </div>

            <div class="contact-field contact-field--full">
                <label asp-for="Input.Message"></label>
                <textarea asp-for="Input.Message" rows="7" placeholder="A sua mensagem..."></textarea>
                <span asp-validation-for="Input.Message"></span>
            </div>

            <div class="contact-actions contact-field--full">
                <button type="submit">Enviar</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
