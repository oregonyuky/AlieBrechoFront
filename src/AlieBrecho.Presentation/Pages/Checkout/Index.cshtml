@page
@model AlieBrecho.Presentation.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = "Checkout";
}

<section class="checkout-shell">
    <div class="checkout-layout">
        <div class="checkout-left">
            <div class="checkout-brand">
                <a class="checkout-brand__logo" asp-page="/Index">Alie <em>Brecho</em></a>
                <div class="checkout-brand__secure">Compra 100% segura</div>
            </div>

            <h1 class="checkout-title">Check<em>out</em></h1>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="notice">@Model.ErrorMessage</div>
            }

            @if (Model.Cart.IsEmpty)
            {
                <div class="checkout-step-card active">
                    <div class="checkout-step-header">
                        <div>
                            <div class="checkout-step-label">Carrinho vazio</div>
                            <div class="checkout-step-summary">Adicione uma peca antes de finalizar o pedido.</div>
                        </div>
                    </div>
                    <div class="checkout-step-body">
                        <a class="btn-confirm" asp-page="/Index">Ver produtos</a>
                    </div>
                </div>
            }
            else
            {
                <div class="progress-bar" id="checkoutProgress">
                    <div class="progress-step active" id="prog-1"><div class="progress-dot"></div>Email</div>
                    <div class="progress-line"></div>
                    <div class="progress-step" id="prog-2"><div class="progress-dot"></div>Dados</div>
                    <div class="progress-line"></div>
                    <div class="progress-step" id="prog-3"><div class="progress-dot"></div>Entrega</div>
                    <div class="progress-line"></div>
                    <div class="progress-step" id="prog-4"><div class="progress-dot"></div>Recebimento</div>
                    <div class="progress-line"></div>
                    <div class="progress-step" id="prog-5"><div class="progress-dot"></div>Pagamento</div>
                </div>

                <form method="post" class="checkout-form" id="checkoutForm" data-subtotal="@Model.Cart.Subtotal.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                    <div class="checkout-step-card active" id="card-1">
                        <div class="checkout-step-header">
                            <div class="checkout-step-header__left">
                                <div class="checkout-step-num" id="num-1">1</div>
                                <div>
                                    <div class="checkout-step-label">E-mail</div>
                                    <div class="checkout-step-summary" id="sum-1">Dados para confirmacao do pedido</div>
                                </div>
                            </div>
                            <button class="btn-edit-step" type="button" data-edit-step="1">Editar</button>
                        </div>
                        <div class="checkout-step-body">
                            <label class="field" id="field-email">
                                E-mail
                                <input asp-for="Input.Email" id="email" type="email" autocomplete="email" placeholder="seu@email.com" required />
                                <span class="field__error">Digite um e-mail valido</span>
                            </label>
                            <button class="btn-confirm" type="button" data-confirm-step="1">Continuar</button>
                        </div>
                    </div>

                    <div class="checkout-step-card" id="card-2">
                        <div class="checkout-step-header">
                            <div class="checkout-step-header__left">
                                <div class="checkout-step-num" id="num-2">2</div>
                                <div>
                                    <div class="checkout-step-label">Dados pessoais</div>
                                    <div class="checkout-step-summary" id="sum-2"></div>
                                </div>
                            </div>
                            <button class="btn-edit-step" type="button" data-edit-step="2">Editar</button>
                        </div>
                        <div class="checkout-step-body checkout-form-grid checkout-form-grid--2">
                            <label class="field" id="field-nome">
                                Nome
                                <input asp-for="Input.FirstName" id="nome" autocomplete="given-name" placeholder="Seu nome" required />
                                <span class="field__error">Nome obrigatorio</span>
                            </label>
                            <label class="field" id="field-sobrenome">
                                Sobrenome
                                <input asp-for="Input.LastName" id="sobrenome" autocomplete="family-name" placeholder="Seu sobrenome" required />
                                <span class="field__error">Sobrenome obrigatorio</span>
                            </label>
                            <label class="field" id="field-cpf">
                                CPF
                                <input asp-for="Input.Cpf" id="cpf" inputmode="numeric" maxlength="14" placeholder="000.000.000-00" required />
                                <span class="field__error">CPF invalido</span>
                            </label>
                            <label class="field" id="field-telefone">
                                Telefone
                                <input asp-for="Input.PhoneNumber" id="telefone" autocomplete="tel" inputmode="tel" placeholder="(00) 00000-0000" required />
                                <span class="field__error">Telefone obrigatorio</span>
                            </label>
                            <button class="btn-confirm full" type="button" data-confirm-step="2">Continuar</button>
                        </div>
                    </div>

                    <div class="checkout-step-card" id="card-3">
                        <div class="checkout-step-header">
                            <div class="checkout-step-header__left">
                                <div class="checkout-step-num" id="num-3">3</div>
                                <div>
                                    <div class="checkout-step-label">Endereco de entrega</div>
                                    <div class="checkout-step-summary" id="sum-3"></div>
                                </div>
                            </div>
                            <button class="btn-edit-step" type="button" data-edit-step="3">Editar</button>
                        </div>
                        <div class="checkout-step-body checkout-form-grid checkout-form-grid--3">
                            <div class="cep-row full">
                                <label class="field" id="field-cep">
                                    CEP
                                    <input asp-for="Input.PostCode" id="cep" autocomplete="postal-code" inputmode="numeric" maxlength="9" placeholder="00000-000" required />
                                    <span class="field__error">CEP invalido</span>
                                </label>
                                <button class="btn-cep" id="btnCep" type="button">Buscar</button>
                            </div>
                            <label class="field wide" id="field-rua">
                                Rua
                                <input asp-for="Input.Street" id="rua" autocomplete="street-address" required />
                                <span class="field__error">Endereco obrigatorio</span>
                            </label>
                            <label class="field" id="field-numero">
                                Numero
                                <input asp-for="Input.Number" id="numero" required />
                                <span class="field__error">Numero obrigatorio</span>
                            </label>
                            <label class="field" id="field-bairro">
                                Bairro
                                <input asp-for="Input.Neighborhood" id="bairro" required />
                                <span class="field__error">Bairro obrigatorio</span>
                            </label>
                            <label class="field" id="field-cidade">
                                Cidade
                                <input asp-for="Input.City" id="cidade" required />
                                <span class="field__error">Cidade obrigatoria</span>
                            </label>
                            <label class="field" id="field-estado">
                                Estado
                                <input asp-for="Input.State" id="estado" maxlength="2" required />
                                <span class="field__error">UF obrigatoria</span>
                            </label>
                            <label class="field full">
                                Complemento
                                <input asp-for="Input.Complement" id="complemento" />
                            </label>
                            <button class="btn-confirm full" type="button" data-confirm-step="3">Continuar</button>
                        </div>
                    </div>

                    <div class="checkout-step-card" id="card-4">
                        <div class="checkout-step-header">
                            <div class="checkout-step-header__left">
                                <div class="checkout-step-num" id="num-4">4</div>
                                <div>
                                    <div class="checkout-step-label">Como voce quer receber?</div>
                                    <div class="checkout-step-summary" id="sum-4"></div>
                                </div>
                            </div>
                            <button class="btn-edit-step" type="button" data-edit-step="4">Editar</button>
                        </div>
                        <div class="checkout-step-body checkout-form-grid checkout-form-grid--3">
                            <input asp-for="Input.DeliveryMode" id="deliveryMode" type="hidden" />
                            <div class="shipping-choice full" id="shippingChoice">
                                <div class="delivery-title">Como voce quer receber?</div>
                                <div class="shipping-choice__grid">
                                    <button class="shipping-choice-card selected" type="button" data-delivery-mode="normal">
                                        <span class="shipping-choice-card__title">Envio Normal</span>
                                        <span class="shipping-choice-card__desc">Finalize o pedido e receba esta compra imediatamente.</span>
                                    </button>
                                    <button class="shipping-choice-card" type="button" data-delivery-mode="bag">
                                        <span class="shipping-choice-card__title">Sacolinha</span>
                                        <span class="shipping-choice-card__desc">Pague agora e acumule pecas por ate 2 meses para enviar tudo junto com um frete menor.</span>
                                    </button>
                                </div>
                            </div>
                            <div class="delivery-section full" id="delivery-section">
                                <div class="delivery-title">Opcao de entrega</div>
                                <div class="delivery-opts" id="deliveryOpts"></div>
                            </div>
                            <button class="btn-confirm full" type="button" data-confirm-step="4">Continuar</button>
                        </div>
                    </div>

                    <div class="checkout-step-card" id="card-5">
                        <div class="checkout-step-header">
                            <div class="checkout-step-header__left">
                                <div class="checkout-step-num" id="num-5">5</div>
                                <div>
                                    <div class="checkout-step-label">Pagamento</div>
                                    <div class="checkout-step-summary" id="sum-5"></div>
                                </div>
                            </div>
                            <button class="btn-edit-step" type="button" data-edit-step="5">Editar</button>
                        </div>
                        <div class="checkout-step-body">
                            <input asp-for="Input.PaymentMethod" id="paymentMethod" type="hidden" />
                            <div class="payment-methods" id="paymentMethods">
                                <button class="payment-method-card selected" type="button" data-payment-method="pix">
                                    <span class="payment-method-card__head">
                                        <img class="payment-method-card__icon" src="~/images/icons/pix.svg" alt="" aria-hidden="true" />
                                        <span class="payment-method-card__title">Pix</span>
                                    </span>
                                    <span class="payment-method-card__desc">Pagamento instantaneo com QR Code seguro do Mercado Pago.</span>
                                </button>
                            </div>
                            <button class="btn-confirm btn-confirm-final" id="btnFinalizar" type="submit">Pagar</button>
                        </div>
                    </div>
                </form>
            }
        </div>

        <aside class="checkout-right">
            <h2 class="summary-title">Resumo do <em>pedido</em></h2>

            @if (Model.Cart.IsEmpty)
            {
                <p class="checkout-empty-summary">Seu carrinho esta vazio.</p>
            }
            else
            {
                <div class="checkout-cart-items">
                    @foreach (var item in Model.Cart.Items)
                    {
                        <div class="checkout-cart-item">
                            <div class="checkout-cart-item__img">
                                @if (!string.IsNullOrWhiteSpace(item.Product.MainImageUrl))
                                {
                                    <img src="@item.Product.MainImageUrl" alt="@item.Product.Name" />
                                }
                                else
                                {
                                    <span>@item.Product.Name</span>
                                }
                                <div class="checkout-cart-item__badge">@item.Quantity</div>
                            </div>
                            <div class="checkout-cart-item__info">
                                <div class="checkout-cart-item__name">@item.Product.Name</div>
                                <div class="checkout-cart-item__variant">@(item.Product.Sizes.FirstOrDefault()?.Size ?? "Tamanho unico")</div>
                                <div class="checkout-cart-item__pricing">
                                    <span class="checkout-cart-item__price">@item.Total.ToString("C")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="cupom-row">
                    <input class="cupom-input" type="text" id="cupomInput" placeholder="Codigo de cupom" />
                    <button class="btn-cupom" type="button" id="btnCupom">Aplicar</button>
                </div>
                <div id="cupomMsg"></div>

                <div class="summary-totals">
                    <div class="total-row">
                        <span class="total-row__label">Subtotal</span>
                        <span class="total-row__val" id="val-subtotal">@Model.Cart.Subtotal.ToString("C")</span>
                    </div>
                    <div class="total-row" id="row-desconto">
                        <span class="total-row__label">Desconto</span>
                        <span class="total-row__val desconto" id="val-desconto">- R$ 0,00</span>
                    </div>
                    <div class="total-row">
                        <span class="total-row__label">Entrega</span>
                        <span class="total-row__val calcular" id="val-entrega">A calcular</span>
                    </div>
                    <div class="total-row total-row--main">
                        <span class="total-row__label">Total</span>
                        <span class="total-row__val" id="val-total">@Model.Cart.Subtotal.ToString("C")</span>
                    </div>
                </div>

                <div class="summary-guarantees">
                    <div class="guarantee">Pagamento seguro e atendimento personalizado</div>
                </div>
            }
        </aside>
    </div>
</section>
