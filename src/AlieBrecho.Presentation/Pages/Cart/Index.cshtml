@page
@model AlieBrecho.Presentation.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Carrinho";
}

<section class="cart-shell">
    <h1>Carrinho</h1>

    @if (Model.Cart.IsEmpty)
    {
        <div class="empty-state">
            <h2>Seu carrinho esta vazio</h2>
            <a class="button" asp-page="/Index">Ver produtos</a>
        </div>
    }
    else
    {
        <div class="cart-lines">
            @foreach (var item in Model.Cart.Items)
            {
                <article class="cart-line">
                    <div>
                        <h2>@item.Product.Name</h2>
                        <span>@item.Product.DisplayPrice.ToString("C")</span>
                    </div>
                    <strong>@item.Total.ToString("C")</strong>
                    <form method="post" asp-page-handler="Remove" asp-route-productId="@item.Product.Id">
                        <button class="icon-button" type="submit" aria-label="Remover">x</button>
                    </form>
                </article>
            }
        </div>

        <aside class="cart-summary">
            <span>Subtotal</span>
            <strong>@Model.Cart.Subtotal.ToString("C")</strong>
            <a class="button" asp-page="/Checkout/Index">Finalizar pedido</a>
            @if (Model.ActiveBag is not null)
            {
                <div class="bag-summary-card">
                    <span>Sacolinha em andamento</span>
                    <strong>@Model.ActiveBag.ItemCount peca(s)</strong>
                    <small>Prazo: @(Model.ActiveBag.ExpirationDate?.ToString("dd/MM/yyyy HH:mm") ?? "a confirmar")</small>
                    <form method="post" asp-page-handler="FinalizeBag" asp-route-bagId="@Model.ActiveBag.Id" data-finalize-bag-form>
                        <button class="button button-secondary" type="submit">Finalizar sacolinha agora</button>
                    </form>
                </div>
            }
        </aside>
    }
</section>
